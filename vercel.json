{
  "buildCommand": "npm install && cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron-forecasts",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron-reset-messages",
      "schedule": "0 1 1 * *"
    }
  ]
}
